---
// REDUCED-MOTION / NO-JS STILL FALLBACK — keep this working whenever the journey changes.
import type { RoomData } from '../lib/journey/types';
import { pad } from '../lib/journey';

interface Props {
  rooms: RoomData[];
}
const { rooms } = Astro.props;
---

<section class="stills" aria-label="Selected spaces">
  {
    rooms.map((r) => (
      <figure class="still">
        <img
          src={`/frames/desktop/${r.id}/frame_${pad(r.desktop)}.jpg`}
          alt={`${r.kicker} by Bravura Builders`}
          loading="lazy"
          decoding="async"
        />
        <figcaption>
          <span class="caption-kicker">{r.kicker}</span>
          <strong>{r.title}</strong>
          <span>{r.body}</span>
        </figcaption>
      </figure>
    ))
  }
</section>

<style>
  /* When the scrub is active (or before the engine has decided), hide the stills. */
  :global(html.has-scrub) .stills {
    display: none;
  }
  :global(html:not(.has-scrub):not(.no-scrub)) .stills {
    display: none;
  }

  .stills {
    background: var(--cine-bg);
    padding: 4rem 1.25rem;
    display: grid;
    gap: 2rem;
  }
  .still {
    margin: 0;
    max-width: 1000px;
    width: 100%;
    margin-inline: auto;
  }
  .still img {
    width: 100%;
    border-radius: 14px;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .still figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 1rem;
    color: #fff;
  }
  .still figcaption strong {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 500;
  }
  .still figcaption span:last-child {
    color: rgba(255, 255, 255, 0.7);
  }
  .caption-kicker {
    display: block;
    font-size: clamp(0.95rem, 1.5vw, 1.15rem);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--highlight);
    margin-bottom: 1rem;
    font-weight: 600;
  }
</style>
