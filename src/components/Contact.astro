---
import { contact } from '../data/rooms';

const { phoneHref, smsHref, emailHref } = contact;
---

<!-- CONTACT — dark, centered, minimal; liquid-glass CTAs. -->
<section class="contact" id="contact">
  <div class="wrap contact-inner">
    <span class="eyebrow">Start a conversation</span>
    <h2>Ready to transform your space?</h2>
    <p>
      Reach out for a free quote. We'll talk through scope, budget, and timeline — and if design or
      renderings are the right first step, we'll quote that separately before any construction bid.
    </p>
    <div class="cta-row">
      <a href={phoneHref} class="glass-btn">Call</a>
      <a href={smsHref} class="glass-btn">Text</a>
      <a href={emailHref} class="glass-btn">Email us</a>
    </div>
  </div>
</section>

<style>
  .contact {
    background: transparent; /* sits on the .closing gradient */
    color: #fff;
    padding: clamp(5rem, 10vw, 8rem) 0 clamp(6rem, 12vw, 9rem);
  }
  /* centered, minimal — echoes the top section */
  .contact-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .contact .eyebrow {
    color: var(--highlight);
  }
  .contact h2 {
    color: #fff;
    font-size: clamp(2.2rem, 4.5vw, 3.4rem);
  }
  .contact p {
    color: rgba(255, 255, 255, 0.72);
    max-width: 540px;
    margin: 0 auto;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.5rem;
    justify-content: center;
  }

  /* liquid-glass CTA buttons (echo the wordmark's glass treatment) */
  .glass-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.5rem;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    color: #fff;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.015));
    border: 1px solid rgba(255, 255, 255, 0.15);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
    backdrop-filter: blur(10px) saturate(150%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 3px 12px rgba(0, 0, 0, 0.15);
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease;
  }
  .glass-btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.1));
    border-color: rgba(255, 255, 255, 0.4);
  }
  .contact-office {
    margin: 2.75rem 0 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
