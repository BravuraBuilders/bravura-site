---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Projects | Bravura Builders"
  description="Finished kitchens, baths, living spaces, and commercial build-outs across metro Atlanta, plus 3D renderings from our design studio."
>
  <section class="page-hero dark on-dark">
    <div class="wrap">
      <span class="eyebrow">Portfolio</span>
      <h1>Projects: photos and renderings.</h1>
      <p class="lede">
        Real finished work from the field, plus design output from the studio. No stock photography
        anywhere on this site.
      </p>
    </div>
  </section>
  <section style="padding-top:0">
    <div class="wrap">
      <div class="filters" role="group" aria-label="Filter projects">
        <button class="chip" aria-pressed="true" data-filter="all">All</button>
        <button class="chip" aria-pressed="false" data-filter="kitchen">Kitchens</button>
        <button class="chip" aria-pressed="false" data-filter="bath">Baths</button>
        <button class="chip" aria-pressed="false" data-filter="living">Living spaces</button>
        <button class="chip" aria-pressed="false" data-filter="interiors">Custom interiors</button>
        <button class="chip" aria-pressed="false" data-filter="commercial">Commercial</button>
        <button class="chip" aria-pressed="false" data-filter="render">Renderings</button>
      </div>
      <div class="proj-grid stagger">
        <div class="card group rv" data-cat="kitchen">
          <div class="slides" tabindex="0" aria-label="Walnut and stone kitchen, 2 photos">
            <img
              src="/img/projects/DSC07647.jpg"
              alt="Kitchen with walnut lowers, white uppers, and black stone waterfall island"
              loading="lazy"
            />
            <img
              src="/img/projects/DSC07653.jpg"
              alt="Kitchen detail with walnut lower cabinets, honed stone, and globe pendant"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Walnut &amp; stone kitchen</b><span>Kitchen</span></div>
        </div>
        <div class="card rv" data-cat="kitchen">
          <img
            src="/img/projects/DSC08136.jpg"
            alt="Galley kitchen with walnut cabinetry and window"
            loading="lazy"
          /><div class="cap"><b>Walnut galley kitchen</b><span>Kitchen</span></div>
        </div>
        <div class="card rv" data-cat="bath">
          <img
            src="/img/projects/DSC08124.jpg"
            alt="Bathroom finished in black herringbone tile with glass shower"
            loading="lazy"
          /><div class="cap"><b>Black herringbone bath</b><span>Bath</span></div>
        </div>
        <div class="card rv" data-cat="bath">
          <img
            src="/img/projects/DSC08123.jpg"
            alt="Bathroom with grey herringbone tile shower and wood vanity"
            loading="lazy"
          /><div class="cap"><b>Grey herringbone bath</b><span>Bath</span></div>
        </div>
        <div class="card rv" data-cat="bath">
          <img
            src="/img/projects/DSC08125.jpg"
            alt="Bathroom with marble-look tile walls and tub"
            loading="lazy"
          /><div class="cap"><b>Marble-look bath</b><span>Bath</span></div>
        </div>
        <div class="card rv" data-cat="living">
          <img
            src="/img/projects/DSC07609.jpg"
            alt="Living room with exposed brick fireplace and chandelier"
            loading="lazy"
          /><div class="cap"><b>Brick fireplace parlor</b><span>Living</span></div>
        </div>
        <div class="card rv" data-cat="living">
          <img
            src="/img/projects/DSC07598.jpg"
            alt="Living room with restored original mantel and new oak floors"
            loading="lazy"
          /><div class="cap"><b>Original mantel living room</b><span>Living</span></div>
        </div>
        <div class="card rv" data-cat="interiors">
          <img
            src="/img/projects/DSC07463.jpg"
            alt="Walk-in closet with white built-in wardrobes and bench"
            loading="lazy"
          /><div class="cap"><b>Walk-in closet</b><span>Custom interiors</span></div>
        </div>
        <div class="card group rv" data-cat="kitchen">
          <div class="slides" tabindex="0" aria-label="Rift oak and brass kitchen, 4 photos">
            <img
              src="/img/projects/IMG_2920.jpg"
              alt="Kitchen with rift-oak cabinets, black appliances, brass pulls"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_2929.jpg"
              alt="Open view of the kitchen with dark island"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_2931.jpg"
              alt="Under-cabinet lighting over the white counter"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_2932.jpg"
              alt="Counter view with matte black faucet"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Rift oak &amp; brass kitchen</b><span>Kitchen</span></div>
        </div>
        <div class="card rv" data-cat="kitchen">
          <img
            src="/img/projects/DSC07404.jpg"
            alt="Kitchen with two-tone cabinets and marble counters"
            loading="lazy"
          /><div class="cap"><b>Two-tone kitchen</b><span>Kitchen</span></div>
        </div>
        <div class="card rv" data-cat="bath">
          <img
            src="/img/projects/DSC07724.jpg"
            alt="Bath with white stacked tile and floating oak vanity"
            loading="lazy"
          /><div class="cap"><b>Stacked-tile bath</b><span>Bath</span></div>
        </div>
        <div class="card rv" data-cat="bath">
          <img
            src="/img/projects/DSC07993.jpg"
            alt="Bathroom with large-format grey stone tile and LED mirror"
            loading="lazy"
          /><div class="cap"><b>Stone-tile bath</b><span>Bath</span></div>
        </div>
        <div class="card group rv" data-cat="interiors">
          <div class="slides" tabindex="0" aria-label="Laundry room, 2 photos">
            <img
              src="/img/projects/IMG_2354.jpg"
              alt="Laundry room with stacked washer and dryer and fluted wood wall"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_2302.jpg"
              alt="Laundry room with fluted dark wood wall and butcher block counter"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Laundry room</b><span>Custom interiors</span></div>
        </div>
        <div class="card group rv" data-cat="interiors">
          <div class="slides" tabindex="0" aria-label="Paneled walls and concealed door, 2 photos">
            <img
              src="/img/projects/IMG_2577.jpg"
              alt="Room with floor-to-ceiling white wall paneling"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_2580.jpg"
              alt="Paneled wall with concealed door opening to a sitting room"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Custom paneling</b><span>Custom interiors</span></div>
        </div>
        <div class="card group rv" data-cat="commercial">
          <div class="slides" tabindex="0" aria-label="Commercial washroom build-out, 5 photos">
            <img
              src="/img/projects/IMG_8964.jpg"
              alt="Commercial washroom with double vanity and fluted wood panel"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_8935.jpg"
              alt="Commercial washroom with row of mirrors and fluted vanity front"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_8958.jpg"
              alt="Commercial washroom with mirrors, partitions, and glazed tile"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_8965.jpg"
              alt="Commercial washroom with long vanity and lit mirrors"
              loading="lazy"
            />
            <img
              src="/img/projects/IMG_9042.jpg"
              alt="Commercial washroom partition stalls"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Commercial washrooms</b><span>Commercial</span></div>
        </div>
        <div class="card group rv" data-cat="render">
          <div class="slides" tabindex="0" aria-label="Sage bath concept renderings, 3 images">
            <img
              src="/img/renders/image1.jpg"
              alt="Rendering of a sage green primary bathroom"
              loading="lazy"
            />
            <img
              src="/img/renders/image2.jpg"
              alt="Rendering of the sage bath with freestanding tub and vanities"
              loading="lazy"
            />
            <img
              src="/img/renders/image3.jpg"
              alt="Rendering of the tub beneath the window in the sage bath"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Sage bath concept</b><span>Rendering</span></div>
        </div>
        <div class="card group rv" data-cat="render">
          <div class="slides" tabindex="0" aria-label="Marble bath concept renderings, 5 images">
            <img
              src="/img/renders/Final_Render_3.jpg"
              alt="Rendering of a walk-in shower with brass fixtures"
              loading="lazy"
            />
            <img
              src="/img/renders/Final_Render__1.jpg"
              alt="Rendering of the bathroom vanity with wood cabinets"
              loading="lazy"
            />
            <img
              src="/img/renders/Final_Render__2.jpg"
              alt="Rendering of the marble bath wet-room passage"
              loading="lazy"
            />
            <img
              src="/img/renders/Final_Render__4.jpg"
              alt="Rendering of the shower approach with brass fixtures"
              loading="lazy"
            />
            <img
              src="/img/renders/Final_Render__5.jpg"
              alt="Rendering of the bath entry and glass partition"
              loading="lazy"
            />
          </div>
          <div class="cap"><b>Marble bath concept</b><span>Rendering</span></div>
        </div>
      </div>
    </div>
  </section>
</Layout>
