---
import Layout from '../layouts/Layout.astro';

const phone = '470-504-3420';
const phoneHref = 'tel:+14705043420';
const email = 'nano@bravurabuilders.com';
const smsHref = 'sms:+14705043420';
const emailHref = `mailto:${email}`;
const address = '11720 Amber Park Dr, Alpharetta GA 30009';

const services = [
  {
    title: 'Renovations & Remodels',
    body:
      'Kitchens, baths, additions, and whole-home renovations executed with the discipline of new construction. Clean job sites, written communication, and a fixed scope you can hold us to.',
  },
  {
    title: 'New Construction',
    body:
      'Ground-up residential and small-multifamily builds across metro Atlanta. Vetted subcontractors, transparent budgets, and project management that keeps every trade accountable.',
  },
  {
    title: "Owner's Representation",
    body:
      'When another contractor holds the build, we sit on your side of the table. Owner’s rep engagements cover scope review, schedule oversight, draw approvals, and quality control so you’re never negotiating alone with the trades.',
  },
  {
    title: 'Consulting',
    body:
      'Pre-purchase walkthroughs, feasibility studies, second opinions on existing scopes or competing bids. A builder’s perspective on the questions you’re weighing — without committing to a full project.',
  },
  {
    title: 'Design & Rendering',
    body:
      'Photoreal 3D renderings and construction-ready plans, sold as a standalone service. Pay a flat design fee and the deliverables — drawings, renderings, and plans — are yours to keep, whether or not you award us the build.',
    featured: true,
  },
];

const projects = [
  { label: 'Open-plan kitchen + great room', location: 'Atlanta, GA', image: '/work/kitchen.jpg' },
  { label: 'Primary bath remodel', location: 'Atlanta, GA', image: '/work/bath.jpg' },
  { label: 'Laundry room remodel', location: 'Atlanta, GA', image: '/work/laundry.jpg' },
  { label: 'New construction', location: 'Atlanta, GA', image: '/work/new-construction.jpg' },
];
---

<Layout>
  <header class="nav">
    <div class="wrap nav-inner">
      <a href="/" class="brand" aria-label="Bravura Builders home">
        <img src="/bravura-logo.png" alt="Bravura Builders" class="brand-logo" width="342" height="144" />
      </a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="wrap hero-inner">
        <span class="eyebrow">· Metro Atlanta ·</span>
        <h1>
          <span class="hero-sep" aria-hidden="true"></span> New Construction <span class="hero-sep" aria-hidden="true"></span><br class="hero-break-mobile" /><span class="hero-sep hero-only-mobile" aria-hidden="true"></span> Remodels <span class="hero-sep" aria-hidden="true"></span> Renovations <span class="hero-sep" aria-hidden="true"></span><br />
          <em>Built with Bravura.</em>
        </h1>
        <p class="lead">
          Bravura Builders is a general contracting firm delivering high-craft
          renovations, new construction, and design services across metro Atlanta.
          We bring the rigor of large-project management to residential and
          small-multifamily work.
        </p>
        <p class="hero-call"><span class="hero-call-inner">Reach Out for a Free Quote</span></p>
        <div class="cta-row">
          <a href={phoneHref} class="btn btn-outline">Call</a>
          <a href={smsHref} class="btn btn-outline">Text</a>
          <a href={emailHref} class="btn btn-outline">Email us</a>
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Services</span>
          <h2>What we do.</h2>
        </div>
        <div class="service-grid">
          {services.map((s) => (
            <article class={`service-card${s.featured ? ' service-card--featured' : ''}`}>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
              {s.featured && <span class="service-tag">Billed independently</span>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="about">
      <div class="wrap about-inner">
        <span class="eyebrow">About</span>
        <article class="dict-entry">
          <header class="dict-head">
            <h2 class="dict-word">bra<span class="dict-dot">·</span>vu<span class="dict-dot">·</span>ra</h2>
            <span class="dict-pron">/brəˈv(y)o͝orə/</span>
          </header>
          <p class="dict-meta"><em>noun</em> · Italian, 16th century</p>
          <p class="dict-def">great technical skill and brilliance shown in a performance or activity.</p>
        </article>
        <p class="about-pitch">
          We are defined by bold design, masterful execution, and the skill to turn
          vision into reality. <strong>Bring Bravura to your next remodel.</strong>
        </p>
        <div class="about-copy">
          <p>
            Bravura was founded to bring discipline and clear communication to a trade
            that often lacks both. Every project runs on a written scope, a defined
            schedule, and a single point of contact — so clients always know what
            comes next and what it costs.
          </p>
          <p>
            We work on renovations, new builds, and design engagements across metro
            Atlanta. Most of our jobs come from referrals; we'd rather do fewer
            projects well than chase volume.
          </p>
        </div>
      </div>
    </section>

    <section class="work" id="work">
      <div class="wrap">
        <div class="section-head">
          <span class="eyebrow">Selected work</span>
          <h2>Recent and in-progress projects.</h2>
        </div>
        <div class="work-grid">
          {projects.map((p) => (
            <figure class="work-tile">
              <img src={p.image} alt={p.label} class="work-image" loading="lazy" decoding="async" />
              <figcaption>
                <strong>{p.label}</strong>
                <span>{p.location}</span>
              </figcaption>
            </figure>
          ))}
        </div>
        <p class="work-note">Representative project styles. Ask us for our active portfolio over a call.</p>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="wrap contact-inner">
        <div>
          <span class="eyebrow">Start a conversation</span>
          <h2>Tell us about your project.</h2>
          <p>
            The fastest way to get a real answer is a phone call. We'll talk through
            scope, budget, and timeline — and if design or renderings are the right
            first step, we'll quote that separately before any construction bid.
            Estimates are always free.
          </p>
          <div class="cta-row">
            <a href={phoneHref} class="btn btn-outline btn-stacked">
              <span class="btn-action">Call</span>
              <span class="btn-target">{phone}</span>
            </a>
            <a href={smsHref} class="btn btn-outline btn-stacked">
              <span class="btn-action">Text</span>
              <span class="btn-target">{phone}</span>
            </a>
            <a href={emailHref} class="btn btn-outline btn-stacked">
              <span class="btn-action">Email us</span>
              <span class="btn-target">{email}</span>
            </a>
          </div>
        </div>
        <aside class="contact-card">
          <dl>
            <dt>Call or text</dt>
            <dd><a href={phoneHref}>{phone}</a></dd>
            <dt>Email</dt>
            <dd><a href={emailHref}>{email}</a></dd>
            <dt>Office</dt>
            <dd>{address}</dd>
          </dl>
        </aside>
      </div>
    </section>
  </main>

  <footer class="foot">
    <div class="wrap foot-inner">
      <span>© {new Date().getFullYear()} Bravura Builders LLC</span>
      <span>Licensed general contractor · Georgia</span>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(250, 248, 245, 0.55);
    backdrop-filter: saturate(150%) blur(14px);
    -webkit-backdrop-filter: saturate(150%) blur(14px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 0;
    padding-bottom: 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand-logo {
    display: block;
    width: 342px;
    height: 144px;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 720px) {
    .brand-logo {
      width: 234px;
      height: 100px;
    }
  }

  .hero {
    padding: clamp(4rem, 10vw, 7rem) 0 clamp(3rem, 7vw, 5rem);
    background:
      radial-gradient(1200px 500px at 80% -10%, rgba(195, 223, 225, 0.5), transparent 60%),
      radial-gradient(900px 400px at -10% 110%, rgba(25, 79, 110, 0.06), transparent 60%);
  }

  .hero-inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-inner .lead {
    margin-left: auto;
    margin-right: auto;
  }

  .hero-inner .cta-row {
    justify-content: center;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-sep {
    display: inline-block;
    width: 1.5px;
    height: 0.85em;
    background: var(--accent);
    vertical-align: -0.05em;
    margin: 0 0.12em;
  }

  .hero-only-mobile {
    display: inline-block;
  }

  @media (max-width: 720px) {
    .hero h1 {
      font-size: clamp(1.6rem, 6.8vw, 2.4rem);
    }
    .hero .hero-call-inner {
      font-size: clamp(1.05rem, 1.54vw, 1.33rem);
    }
    .hero .cta-row .btn {
      padding: 0.6rem 1rem;
      font-size: 0.7rem;
    }
  }

  .lead {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    color: var(--muted);
    max-width: 640px;
    margin-bottom: 2rem;
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-call {
    margin: 0 0 1.25rem;
  }

  .hero-call-inner {
    display: inline-block;
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 500;
    font-style: normal;
    color: var(--accent-deep);
    font-size: clamp(1.5rem, 2.2vw, 1.9rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
    background: var(--highlight);
    padding: 0.35em 0.7em;
    border-radius: 6px;
  }

  .dict-entry {
    margin: 1.25rem 0 1.75rem;
    padding: 1.75rem 0 1.75rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .dict-head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 0.35rem;
  }

  .dict-word {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.9rem, 4vw, 2.5rem);
    font-weight: 500;
    margin: 0;
    color: var(--ink);
  }

  .dict-dot {
    color: var(--accent);
    margin: 0 0.05em;
  }

  .dict-pron {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    color: var(--accent);
    font-size: 1.1rem;
  }

  .dict-meta {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 0.9rem;
    letter-spacing: 0.02em;
  }

  .dict-meta em {
    font-style: italic;
    color: var(--accent);
  }

  .dict-def {
    margin: 0;
    color: var(--ink);
    line-height: 1.55;
    font-size: 1.05rem;
  }

  .section-head {
    margin-bottom: 3rem;
    max-width: 720px;
  }

  .services {
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  @media (max-width: 1080px) {
    .service-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .service-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    background: var(--surface);
    padding: 1.5rem 1.25rem;
    border-radius: 14px;
    border: 1px solid var(--rule);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .service-card h3 {
    font-size: 1.05rem;
  }

  .service-card p {
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .service-card h3 {
    margin-bottom: 0.75rem;
  }

  .service-card p {
    margin-bottom: 0;
  }

  .service-card--featured {
    background: linear-gradient(180deg, #fff 0%, #f0f7f8 100%);
    border-color: rgba(25, 79, 110, 0.25);
  }

  .service-tag {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: var(--highlight);
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .about {
    padding: clamp(3rem, 7vw, 5rem) 0;
    background: var(--surface);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .about-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .about-pitch {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    line-height: 1.45;
    color: var(--ink);
    margin: 0 0 2rem;
  }

  .about-pitch strong {
    color: var(--accent);
    font-weight: 500;
    font-style: italic;
  }

  .about-copy p:last-child {
    margin-bottom: 0;
  }

  .work {
    padding: clamp(4rem, 8vw, 6rem) 0;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .work-tile {
    margin: 0;
  }

  .work-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 14px;
    border: 1px solid var(--rule);
    background: var(--highlight);
    transition: transform 0.4s ease;
  }

  .work-tile:hover .work-image {
    transform: scale(1.015);
  }

  .work-tile figcaption {
    display: flex;
    flex-direction: column;
    padding: 0.9rem 0.25rem 0;
    font-size: 0.95rem;
  }

  .work-tile figcaption span {
    color: var(--muted);
    font-size: 0.85rem;
  }

  .work-note {
    margin-top: 2rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .contact {
    padding: clamp(4rem, 8vw, 6rem) 0;
    background: var(--accent);
    color: #fff;
  }

  .contact .eyebrow {
    color: var(--highlight);
  }

  .contact h2 {
    color: #fff;
  }

  .contact p {
    color: rgba(255, 255, 255, 0.78);
    max-width: 520px;
  }

  .contact .btn-primary {
    background: #fff;
    color: var(--accent);
  }

  .contact .btn-primary:hover {
    background: var(--highlight);
  }

  .contact .btn-outline {
    background: #fff;
    color: var(--accent-deep);
    border-color: transparent;
  }

  .contact .btn-outline:hover {
    background: var(--highlight);
    color: var(--accent-deep);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 6vw, 4rem);
    align-items: start;
  }

  @media (max-width: 760px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }

  .contact-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 16px;
    padding: 1.75rem;
  }

  .contact-card dl {
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  .contact-card dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--highlight);
    margin-bottom: 0.15rem;
  }

  .contact-card dd {
    margin: 0;
    color: #fff;
    font-size: 0.98rem;
  }

  .contact-card a {
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
  }

  .contact-card a:hover {
    text-decoration: none;
    border-bottom-color: #fff;
  }

  .foot {
    padding: 1.75rem 0 2.25rem;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .foot-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
