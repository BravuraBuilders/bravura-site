---
import Layout from '../layouts/Layout.astro';
import Loader from '../components/Loader.astro';
import Nav from '../components/Nav.astro';
import HeroLogo from '../components/HeroLogo.astro';
import Intro from '../components/Intro.astro';
import Journey from '../components/Journey.astro';
import Stills from '../components/Stills.astro';
import Manifesto from '../components/Manifesto.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { rooms } from '../data/rooms';
---

<Layout>
  <Loader />
  <Nav />
  <HeroLogo />

  <main>
    <h1 class="sr-only">Bravura Builders — kitchen, bath &amp; home renovations in metro Atlanta</h1>
    <Intro />
    <Journey rooms={rooms} />
    <Stills rooms={rooms} />

    <!-- CLOSING: light floor colour at the top (blends into the bedroom's bottom)
         fading down to the dark theme by the page bottom — the mirror of the sky. -->
    <div class="closing">
      <Manifesto />
      <Contact />
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { rooms } from '../data/rooms';
  import { initJourney } from '../lib/journey';

  initJourney(rooms);
</script>

<style>
  /* Starts at the bedroom floor colour (top) and fades down to the dark theme by
     the bottom of the page — the mirror of the sky at the top. The last frame is
     left crisp; this section carries the blend. */
  .closing {
    background: linear-gradient(180deg, #63503b 0%, #63503b 5%, var(--cine-bg) 100%);
  }
</style>
