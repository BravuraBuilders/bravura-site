---
// Self-hosted fonts (Fontsource) — no render-blocking Google Fonts CDN fetch.
// Weights must cover everything global.css and the components use.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/500-italic.css';
// Preload the two above-the-fold-critical faces: Inter 700 (hero wordmark),
// Playfair 500 (caption titles / headings).
import inter700Url from '@fontsource/inter/files/inter-latin-700-normal.woff2?url';
import playfair500Url from '@fontsource/playfair-display/files/playfair-display-latin-500-normal.woff2?url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bravura Builders — Kitchen, Bath & Home Renovations in Metro Atlanta',
  description = 'Bravura Builders transforms the rooms you use most — kitchens, baths, and laundry rooms — into beautifully constructed spaces. High-craft renovations and new construction across metro Atlanta.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL('/og.jpg', Astro.site ?? Astro.url)} />
    <link rel="preload" as="font" type="font/woff2" href={inter700Url} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={playfair500Url} crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
