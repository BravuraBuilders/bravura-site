---
// Self-hosted fonts (Fontsource) — no render-blocking Google Fonts CDN.
// Blueprint uses Inter across the board (headings at 800, body 400/600).
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import inter800Url from '@fontsource/inter/files/inter-latin-800-normal.woff2?url';
import inter400Url from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}
const { title, description, ogImage = '/og.jpg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;

// Local-business structured data. Every fact here is confirmed (see CLAUDE.md
// "Key content facts") — do not add ratings, hours, or service claims without Yossi.
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  name: 'Bravura Builders',
  slogan: 'Technical Skill, Brilliant Design, Flawless Results.',
  url: 'https://bravurabuilders.com',
  logo: 'https://bravurabuilders.com/img/logo.png',
  image: 'https://bravurabuilders.com/og.jpg',
  telephone: '+1-470-504-3420',
  email: 'yossi@bravurabuilders.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '11720 Amber Park Dr, Ste 160 PMB 1157',
    addressLocality: 'Alpharetta',
    addressRegion: 'GA',
    postalCode: '30009',
    addressCountry: 'US',
  },
  areaServed: 'Metro Atlanta, GA',
  founder: { '@type': 'Person', name: 'Joseph Kievman' },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#16283C" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Bravura Builders" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? Astro.url).href} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preload" as="font" type="font/woff2" href={inter800Url} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={inter400Url} crossorigin />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <div
      class="lightbox"
      id="lightbox"
      hidden
      role="dialog"
      aria-modal="true"
      aria-label="Photo viewer"
    >
      <button class="lb-close" type="button" aria-label="Close photo viewer">&times;</button>
      <button class="lb-nav prev" type="button" aria-label="Previous photo">&lsaquo;</button>
      <img alt="" />
      <button class="lb-nav next" type="button" aria-label="Next photo">&rsaquo;</button>
      <div class="lb-cap"></div>
    </div>

    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>
