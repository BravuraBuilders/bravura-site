---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bravura Builders — Kitchen, Bath & Home Renovations in Metro Atlanta',
  description = 'Bravura Builders transforms the rooms you use most — kitchens, baths, and laundry rooms — into beautifully constructed spaces. High-craft renovations and new construction across metro Atlanta.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --accent: #194f6e;
    --accent-dark: #0f3a52;
    --accent-deep: #062032;
    --cine-bg: #081a28;
    --highlight: #b8c8e0;
    --bg: #faf8f5;
    --surface: #ffffff;
    --ink: #0d1b22;
    --muted: #4a5d68;
    --rule: rgba(13, 27, 34, 0.1);
    --max: 1200px;
    --pad: clamp(1.25rem, 4vw, 2.5rem);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--cine-bg);
  }

  body {
    font-family:
      'Inter',
      system-ui,
      -apple-system,
      sans-serif;
    color: var(--ink);
    background: var(--cine-bg);
    font-size: 17px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1,
  h2,
  h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.1;
    margin: 0 0 0.6em;
    color: var(--ink);
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
  }

  h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  h3 {
    font-size: 1.25rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 0 0 1em;
    color: var(--muted);
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--pad);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      transform 0.15s ease,
      background 0.15s ease;
    border: 1px solid transparent;
  }

  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--accent-dark);
  }

  .btn-outline {
    background: var(--highlight);
    color: var(--accent-deep);
    border-color: transparent;
  }

  .btn-outline:hover {
    background: var(--accent);
    color: #fff;
  }

  .btn-solid {
    background: #fff;
    color: var(--accent-deep);
    border-color: transparent;
  }

  .btn-solid:hover {
    background: var(--highlight);
    color: var(--accent-deep);
  }

  .btn-stacked {
    flex-direction: column;
    align-items: center;
    gap: 0.05rem;
    padding-top: 0.55rem;
    padding-bottom: 0.55rem;
    line-height: 1.15;
  }

  .btn-stacked .btn-action {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.75;
    font-weight: 600;
  }

  .btn-stacked .btn-target {
    font-size: 1rem;
    font-weight: 600;
  }

  .eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 1rem;
    display: block;
  }
</style>
